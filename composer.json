{
    "name": "codewithdiki/product-module",
    "description": "Minimum product module for Laravel applications.",
    "keywords": [
        ":vendor_name",
        "laravel",
        "product-module"
    ],
    "homepage": "https://github.com/codewithdiki/product-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Diki Akbar Asyidiq",
            "email": "diki.akbar1304@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "spatie/laravel-data": "^4.22",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^11.1.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "CodeWithDiki\\ProductModule\\": "src/",
            "CodeWithDiki\\ProductModule\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodeWithDiki\\ProductModule\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodeWithDiki\\ProductModule\\ProductModuleServiceProvider"
            ],
            "aliases": {
                "ProductModule": "CodeWithDiki\\ProductModule\\Facades\\ProductModule"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
